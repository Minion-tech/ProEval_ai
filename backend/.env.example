# --- ProEval AI Backend: Production Environment Template ---

# [CORE]
PROJECT_NAME="ProEval AI"
API_V1_STR="/api/v1"
DEBUG=False
# For Render.com, use: ["https://your-frontend.vercel.app"]
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# [DATABASE]
# For Neon.tech, use the pooled connection string (starts with postgresql://...)
DATABASE_URL="postgresql+asyncpg://user:password@hostname:5432/dbname?ssl=require"

# [SECURITY]
# Generate a strong key using: openssl rand -hex 32
JWT_SECRET="change-this-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520
OTP_ENABLED=True

# [MAIL] - For OTP Delivery
MAIL_USERNAME="your-email@gmail.com"
MAIL_PASSWORD="your-app-password"
MAIL_FROM="noreply@proeval.ai"
MAIL_PORT=587
MAIL_SERVER="smtp.gmail.com"
MAIL_FROM_NAME="ProEval AI"
MAIL_TLS=True
MAIL_SSL=False

# [AI PROVIDERS]
# Priority: "gemini,groq,nvidia" (Gemini is fastest for free tier)
AI_PROVIDER_PRIORITY="gemini,groq,nvidia"
GEMINI_API_KEY="your-key"
GEMINI_MODEL="gemini-1.5-flash"
GROQ_API_KEY="your-key"
GROQ_MODEL="llama-3.1-70b-versatile"
NVIDIA_API_KEY="your-key"
AI_REQUEST_TIMEOUT_SECONDS=90

# [INTEGRATIONS]
# ElevenLabs for AI Technical Viva
ELEVENLABS_WEBHOOK_SECRET="your-webhook-secret"
NEXT_PUBLIC_ELEVENLABS_AGENT_ID="your-agent-id"

# [QUEUE]
# On Render Free Tier, set EVALUATION_QUEUE_ENABLED=False to use in-process tasks
EVALUATION_QUEUE_ENABLED=False
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
